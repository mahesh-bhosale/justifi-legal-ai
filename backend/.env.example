# Database (use pooled connection in production, e.g. port 6543)
DATABASE_URL=postgresql://user:password@host:6543/postgres

PORT=3001
NODE_ENV=development

# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=
# Short-lived access token; use refresh token + /api/auth/refresh for sessions
JWT_EXPIRES_IN=15m

REDIS_URL=redis://localhost:6379

# Kafka — set SSL/SASL in production
KAFKA_BROKER=localhost:9092
KAFKA_SSL=false
KAFKA_CLIENT_ID=justifi-legal-ai
KAFKA_GROUP_ID=justifi-backend-group

SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_CASE_DOCUMENTS_BUCKET=case-documents

# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
MESSAGE_ENCRYPTION_KEY=
# Generate: node -e "console.log(require('crypto').randomBytes(16).toString('hex'))"
IP_HASH_SALT=

FRONTEND_URL=http://localhost:3000
